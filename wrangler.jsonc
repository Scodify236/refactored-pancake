{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "refactored-pancake",
  "compatibility_date": "2026-07-17",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "gcx",
      "database_id": "8b346736-1d0d-4df5-8b16-e826d09b76a4"
    }
  ]
}
