{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "refactored-pancake",
  "compatibility_date": "2026-07-17",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "gcx-db",
      "database_id": "fe59a4a2-0944-48a5-b114-dbb043f3a441"
    }
  ]
}
